<h1>レシート詳細</h1>

<p>ステータス:
  <%= case @receipt.status
      when "pending"    then "未処理"
      when "processing" then "処理中"
      when "done"       then "完了"
      when "failed"     then "失敗"
      end %>
</p>

<% if @receipt.image.attached? %>
  <%= image_tag @receipt.image, style: "max-width: 400px;" %>
<% end %>

<% if @receipt.pending? || @receipt.failed? %>
  <%= button_to "OCRを実行する", ocr_receipt_path(@receipt),
        method: :post,
        data: { turbo_confirm: "OCR処理を実行しますか？" } %>
<% end %>

<% if @receipt.done? %>
  <%= link_to "補正・登録フォームへ", correct_receipt_path(@receipt),
        style: "display: inline-block; padding: 8px 16px;" %>
<% end %>

<% if @receipt.raw_text.present? %>
  <h2>OCR抽出テキスト</h2>
  <pre><%= @receipt.raw_text %></pre>
<% end %>

<%= button_to "削除", receipt_path(@receipt),
      method: :delete,
      data: { turbo_confirm: "削除しますか？" } %>