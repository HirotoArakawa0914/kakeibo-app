<h1>OCR補正フォーム</h1>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

  <%# 左側: レシート画像 %>
  <div>
    <h2>レシート画像</h2>
    <% if @receipt.image.attached? %>
      <%= image_tag @receipt.image, style: "max-width: 100%;" %>
    <% end %>

    <% if @receipt.raw_text.present? %>
      <h3>OCR抽出テキスト</h3>
      <pre style="background: #f5f5f5; padding: 12px; font-size: 12px;
                  overflow-y: auto; max-height: 300px;">
        <%= @receipt.raw_text %>
      </pre>
    <% end %>
  </div>

  <%# 右側: 補正フォーム %>
  <div>
    <h2>収支データ入力</h2>
    <p style="color: #888; font-size: 13px;">
      OCRの抽出結果を確認・修正して登録してください
    </p>

    <%= form_with model: @transaction_form,
                  url: register_receipt_path(@receipt),
                  method: :post do |f| %>

      <% if @transaction_form.errors.any? %>
        <div>
          <% @transaction_form.errors.full_messages.each do |msg| %>
            <p style="color: red;"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div style="margin-bottom: 16px;">
        <%= f.label :transaction_type, "種別" %>
        <%= f.select :transaction_type,
              [["収入", "income"], ["支出", "expense"]],
              { include_blank: "選択してください" },
              { style: "display: block; width: 100%;" } %>
      </div>

      <div style="margin-bottom: 16px;">
        <%= f.label :amount, "金額（円）" %>
        <%= f.number_field :amount, min: 1,
              style: "display: block; width: 100%;" %>
      </div>

      <div style="margin-bottom: 16px;">
        <%= f.label :date, "日付" %>
        <%= f.date_field :date,
              style: "display: block; width: 100%;" %>
      </div>

      <div style="margin-bottom: 16px;">
        <%= f.label :category_id, "カテゴリ" %>
        <%= f.collection_select :category_id,
              @categories, :id, :name,
              { include_blank: "未分類" },
              { style: "display: block; width: 100%;" } %>
      </div>

      <div style="margin-bottom: 16px;">
        <%= f.label :memo, "メモ（店名など）" %>
        <%= f.text_field :memo,
              style: "display: block; width: 100%;" %>
      </div>

      <%= f.submit "収支データとして登録",
            style: "padding: 8px 16px; cursor: pointer;" %>
    <% end %>
  </div>

</div>