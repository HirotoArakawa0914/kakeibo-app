<h1 class="text-2xl font-bold text-gray-800 mb-6">ダッシュボード</h1>

<%# AIアドバイスパネル %>
<% if @ai_advice.present? %>
  <div class="mb-6 p-5 bg-indigo-50 border border-indigo-200 rounded-xl">
    <h2 class="text-sm font-semibold text-indigo-700 mb-2">💡 AIアドバイス</h2>
    <div class="text-sm text-indigo-900 leading-relaxed whitespace-pre-wrap"><%= @ai_advice %></div>
  </div>
<% end %>

<%# グラフエリア %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <%# 月別支出合計 %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">月別支出合計</h2>
    <canvas id="monthlyExpenseChart"></canvas>
  </div>

  <%# カテゴリ別内訳 %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">カテゴリ別支出（当月）</h2>
    <% if @category_expense.empty? %>
      <p class="text-sm text-gray-400 text-center py-8">当月のデータがありません</p>
    <% else %>
      <div style="max-width: 280px; margin: 0 auto;">
        <canvas id="categoryExpenseChart"></canvas>
      </div>
    <% end %>
  </div>

  <%# 収支バランス %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">収支バランス（過去6ヶ月）</h2>
    <canvas id="monthlyBalanceChart"></canvas>
  </div>

  <%# 日別推移 %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">日別支出推移（当月）</h2>
    <% if @daily_expense.empty? %>
      <p class="text-sm text-gray-400 text-center py-8">当月のデータがありません</p>
    <% else %>
      <canvas id="dailyExpenseChart"></canvas>
    <% end %>
  </div>

</div>

<script>
  new Chart(document.getElementById("monthlyExpenseChart"), {
    type: "bar",
    data: {
      labels: <%= raw @monthly_expense.map { |d| d[:label] }.to_json %>,
      datasets: [{
        label: "支出合計（円）",
        data: <%= raw @monthly_expense.map { |d| d[:amount] }.to_json %>,
        backgroundColor: "rgba(99, 102, 241, 0.6)",
        borderRadius: 4
      }]
    },
    options: { plugins: { legend: { display: false } } }
  });

  <% unless @category_expense.empty? %>
  new Chart(document.getElementById("categoryExpenseChart"), {
    type: "doughnut",
    data: {
      labels: <%= raw @category_expense.map { |d| d[:label] }.to_json %>,
      datasets: [{
        data: <%= raw @category_expense.map { |d| d[:amount] }.to_json %>,
        backgroundColor: <%= raw @category_expense.map { |d| d[:color] }.to_json %>
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { position: "bottom" } }
    }
  });
  <% end %>

  new Chart(document.getElementById("monthlyBalanceChart"), {
    type: "bar",
    data: {
      labels: <%= raw @monthly_balance.map { |d| d[:label] }.to_json %>,
      datasets: [
        {
          label: "収入（円）",
          data: <%= raw @monthly_balance.map { |d| d[:income] }.to_json %>,
          backgroundColor: "rgba(99, 102, 241, 0.6)",
          borderRadius: 4
        },
        {
          label: "支出（円）",
          data: <%= raw @monthly_balance.map { |d| d[:expense] }.to_json %>,
          backgroundColor: "rgba(239, 68, 68, 0.6)",
          borderRadius: 4
        }
      ]
    }
  });

  <% unless @daily_expense.empty? %>
  new Chart(document.getElementById("dailyExpenseChart"), {
    type: "line",
    data: {
      labels: <%= raw @daily_expense.map { |d| d[:label] }.to_json %>,
      datasets: [{
        label: "支出（円）",
        data: <%= raw @daily_expense.map { |d| d[:amount] }.to_json %>,
        borderColor: "rgba(99, 102, 241, 0.8)",
        backgroundColor: "rgba(99, 102, 241, 0.1)",
        tension: 0.3,
        fill: true
      }]
    },
    options: { plugins: { legend: { display: false } } }
  });
  <% end %>
</script>