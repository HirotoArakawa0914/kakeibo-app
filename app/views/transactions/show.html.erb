<h1 class="text-2xl font-bold text-gray-800 mb-6">収支詳細</h1>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 max-w-lg">
  <dl class="space-y-4">
    <div class="flex justify-between py-2 border-b border-gray-100">
      <dt class="text-sm text-gray-500">日付</dt>
      <dd class="text-sm font-medium text-gray-800"><%= @transaction.date %></dd>
    </div>
    <div class="flex justify-between py-2 border-b border-gray-100">
      <dt class="text-sm text-gray-500">種別</dt>
      <dd>
        <% if @transaction.transaction_type == "income" %>
          <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">収入</span>
        <% else %>
          <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">支出</span>
        <% end %>
      </dd>
    </div>
    <div class="flex justify-between py-2 border-b border-gray-100">
      <dt class="text-sm text-gray-500">金額</dt>
      <dd class="text-sm font-bold <%= @transaction.transaction_type == 'income' ? 'text-blue-600' : 'text-red-600' %>">
        <%= number_with_delimiter(@transaction.amount) %>円
      </dd>
    </div>
    <div class="flex justify-between py-2 border-b border-gray-100">
      <dt class="text-sm text-gray-500">カテゴリ</dt>
      <dd class="text-sm text-gray-800"><%= @transaction.category&.name || "未分類" %></dd>
    </div>
    <div class="flex justify-between py-2 border-b border-gray-100">
      <dt class="text-sm text-gray-500">メモ</dt>
      <dd class="text-sm text-gray-800"><%= @transaction.memo %></dd>
    </div>
  </dl>

  <div class="mt-6 pt-4 border-t border-gray-100">
    <h2 class="text-sm font-medium text-gray-700 mb-3">レシート</h2>
    <% if @transaction.receipt.present? %>
      <%= link_to "レシートを確認する", receipt_path(@transaction.receipt),
            class: "text-sm text-indigo-600 hover:underline" %>
    <% else %>
      <p class="text-sm text-gray-400 mb-2">レシートは登録されていません</p>
      <%= link_to "レシートをアップロード", new_transaction_receipt_path(@transaction),
            class: "text-sm text-indigo-600 hover:underline" %>
    <% end %>
  </div>
</div>