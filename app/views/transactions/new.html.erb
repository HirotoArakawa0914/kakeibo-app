<h1>収支登録</h1>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 24px;">

  <%# 手動入力 %>
  <div style="border: 1px solid #ddd; border-radius: 8px; padding: 24px;">
    <h2>手動入力</h2>
    <p style="color: #888; font-size: 13px;">日付・金額・カテゴリを直接入力して登録します。</p>
    <%= render "form", transaction: @transaction %>
  </div>

  <%# OCRで登録 %>
  <div style="border: 1px solid #ddd; border-radius: 8px; padding: 24px;">
    <h2>レシートから登録（OCR）</h2>
    <p style="color: #888; font-size: 13px;">レシートを撮影・アップロードしてOCRで自動入力します。</p>

    <%= form_with url: upload_receipt_path, method: :post, multipart: true do |f| %>
      <div style="margin-bottom: 16px;">
        <%= f.label :image, "レシート画像を選択" %>
        <%= f.file_field :image, accept: "image/*",
              style: "display: block; margin-top: 8px;" %>
      </div>
      <%= f.submit "アップロードしてOCR開始",
            style: "padding: 8px 16px; cursor: pointer;" %>
    <% end %>
  </div>

</div>