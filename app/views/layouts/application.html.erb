<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "KaKeiBO" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="KaKeiBO">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="/assets/tailwind.css">
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">

    <%# ナビゲーション %>
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <span class="text-lg font-bold text-indigo-600">💰 KaKeiBO</span>
          <%= link_to "ダッシュボード", dashboard_path,
                class: "text-sm text-gray-600 hover:text-indigo-600 transition" %>
          <%= link_to "収支一覧", transactions_path,
                class: "text-sm text-gray-600 hover:text-indigo-600 transition" %>
          <%= link_to "カテゴリ管理", categories_path,
                class: "text-sm text-gray-600 hover:text-indigo-600 transition" %>
        </div>
        <div class="flex items-center gap-4">
          <% if user_signed_in? %>
            <span class="text-xs text-gray-400"><%= current_user.email %></span>
            <%= link_to "ログアウト", destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "text-sm text-gray-600 hover:text-red-500 transition" %>
          <% end %>
        </div>
      </div>
    </nav>

    <%# メインコンテンツ %>
    <main class="max-w-6xl mx-auto px-4 py-8">

      <%# フラッシュメッセージ %>
      <% if notice %>
        <div class="mb-6 px-4 py-3 bg-green-50 border border-green-200
                    text-green-800 rounded-lg text-sm">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200
                    text-red-800 rounded-lg text-sm">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

  </body>
</html>